#!name=po0 防火墙自动加白
#!desc=调用 po0 防火墙 API 将本机当前出口 IP 加入白名单。支持多 token（英文逗号分割，对应多台机器），network-changed 事件与每 10 分钟 cron 自动触发，附带手动刷新面板。
#!category=po0
#!author=reallinzc
#!arguments=tokens:""
#!arguments-desc=tokens: po0 防火墙 API token（pgnfw_ 开头），多台机器用英文逗号 , 分割；可选在 token 后加 @槽位（如 pgnfw_xxx@0）钉固定坑位、永不被淘汰。

[Rule]
# 加白 API 必须直连，确保 API 看到的是本机真实出口 IP 而不是代理出口
IP-CIDR,124.221.69.228/32,DIRECT,no-resolve

[Script]
po0-fw-cron = type=cron,cronexp="*/10 * * * *",script-path=https://raw.githubusercontent.com/panghuchi/po0fw/main/scripts/po0-firewall-whitelist.js,timeout=60,argument="tokens={{{tokens}}}"
po0-fw-event = type=event,event-name=network-changed,script-path=https://raw.githubusercontent.com/panghuchi/po0fw/main/scripts/po0-firewall-whitelist.js,timeout=60,argument="tokens={{{tokens}}}"
po0-fw-panel = type=generic,script-path=https://raw.githubusercontent.com/panghuchi/po0fw/main/scripts/po0-firewall-whitelist.js,timeout=60,argument="tokens={{{tokens}}}"

[Panel]
po0-fw = script-name=po0-fw-panel,title=po0 防火墙加白,content=点击刷新,update-interval=300
