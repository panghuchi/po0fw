#!name=po0 防火墙自动加白
#!desc=调用 po0 防火墙 API 将本机当前出口 IP 加入白名单。支持多 token（英文逗号分割），network-changed 事件与每 10 分钟 cron 自动触发。
#!author=reallinzc
#!homepage=https://github.com/panghuchi/po0fw
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Panel.png

[Argument]
tokens = input,"",tag=API tokens,desc=po0 防火墙 API token（pgnfw_ 开头）；多台机器用英文逗号分割；可选 token 后加 @槽位（如 pgnfw_xxx@0）钉固定坑位永不被淘汰

[Rule]
IP-CIDR,124.221.69.228/32,DIRECT,no-resolve

[Script]
cron "*/10 * * * *" script-path=https://raw.githubusercontent.com/panghuchi/po0fw/main/scripts/po0-firewall-whitelist.js, timeout=60, tag=po0-fw-cron, argument=[{tokens}]
network-changed script-path=https://raw.githubusercontent.com/panghuchi/po0fw/main/scripts/po0-firewall-whitelist.js, timeout=60, tag=po0-fw-event, argument=[{tokens}]
